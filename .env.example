# ===============================================
# VARIABLES D'ENVIRONNEMENT - MLC Gestion Membres
# ===============================================

# Supabase Configuration
# ----------------------
# Récupérer les valeurs de https://app.supabase.com/project/[PROJECT]/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Backend Local (pour développement avec Express)
# ----------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/mlc_db
PORT=5000

# Notes:
# - Les variables VITE_* sont exposées au frontend via Vite
# - Les autres variables sont côté serveur seulement
# - Sur Netlify, configurer ces variables dans: Site settings → Build & deploy → Environment
# - PASSWORD ne doit JAMAIS être commité dans git (utiliser .env.local localement)
